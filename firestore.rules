
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.uid == '6BXkgq9KkCY8ZPBvSbMV6m5OuAV2';
    }

    function isAdmin() {
      if (isSuperAdmin()) {
        return true;
      }
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Global Super Admin Bypass ---
    // This recursive match covers all documents for the super admin
    match /{allPaths=**} {
      allow read, write: if isSuperAdmin();
    }

    // --- Collection Rules ---

    match /adminUsers/{adminId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    match /shops/{shopId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin() || isOwner(shopId);
      
      match /products/{productId} {
        allow get, list: if isSignedIn();
        allow write: if isAdmin() || isOwner(shopId);
      }
    }

    match /pings/{pingId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    // --- Collection Group Rules ---
    // Explicitly allow listing products and other items across the database for authorized roles
    
    match /{path=**}/products/{productId} {
      allow list: if isAdmin() || isSignedIn();
    }

    match /{path=**}/subscriptions/{subscriptionId} {
      allow list: if isAdmin();
    }

    match /{path=**}/purchases/{purchaseId} {
      allow list: if isAdmin();
    }
  }
}
