
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Security Definition ---
    // Deployment Trigger: 2024-03-16-v2.1
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Hardcoded Super Admin UID for emergency access and platform bootstrapping
    function isSuperAdmin() {
      return isSignedIn() && request.auth.uid == '6BXkgq9KkCY8ZPBvSbMV6m5OuAV2';
    }

    // Standard Admin check: Either the Super Admin or a user registered in the adminUsers collection
    function isAdmin() {
      return isSuperAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid)));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Global Super Admin Bypass (Primary Rule) ---
    match /{allPaths=**} {
      allow read, write: if isSuperAdmin();
    }

    // --- Collection Specific Rules ---

    match /adminUsers/{adminId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    match /shops/{shopId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin() || isOwner(shopId);
      
      match /products/{productId} {
        allow get, list: if isSignedIn();
        allow write: if isAdmin() || isOwner(shopId);
      }
    }

    match /pings/{pingId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    // --- Collection Group Rules ---
    // These allow the dashboard to query products across all shops simultaneously
    
    match /{path=**}/products/{productId} {
      allow list: if isAdmin() || isSignedIn();
    }

    match /{path=**}/subscriptions/{subscriptionId} {
      allow list: if isAdmin();
    }
  }
}
