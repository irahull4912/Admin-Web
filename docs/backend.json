
{
  "entities": {
    "AdminUser": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AdminUser",
      "type": "object",
      "description": "Represents an administrator account within the AdminVault system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the AdminUser entity."
        },
        "email": {
          "type": "string",
          "description": "The email address of the administrator, used for login and contact.",
          "format": "email"
        },
        "name": {
          "type": "string",
          "description": "The display name of the administrator."
        },
        "lastLogin": {
          "type": "string",
          "description": "Timestamp of the administrator's last successful login.",
          "format": "date-time"
        },
        "role": {
          "type": "string",
          "description": "The role assigned to the administrator (e.g., 'SuperAdmin', 'Editor'), determining their access level."
        }
      },
      "required": [
        "id",
        "email",
        "name",
        "role"
      ]
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a general user of the platform, distinct from administrators or sellers.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "The email address of the user, used for identification and communication.",
          "format": "email"
        },
        "name": {
          "type": "string",
          "description": "The display name of the user."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user registered on the platform.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp of the user's last profile update.",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "description": "The current status of the user account (e.g., 'Active', 'Suspended', 'Inactive')."
        },
        "location": {
          "type": "string",
          "description": "The user's primary geographical location or address."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The user's contact phone number."
        },
        "role": {
          "type": "string",
          "description": "The user's assigned role on the platform."
        }
      },
      "required": [
        "id",
        "email",
        "name",
        "createdAt",
        "status"
      ]
    },
    "Seller": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Seller",
      "type": "object",
      "description": "Represents a registered shop or business on the platform.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Seller entity."
        },
        "name": {
          "type": "string",
          "description": "The official name of the seller's shop."
        },
        "ownerName": {
          "type": "string",
          "description": "The full name of the shop owner."
        },
        "contactEmail": {
          "type": "string",
          "description": "The primary contact email address.",
          "format": "email"
        },
        "contactNumber": {
          "type": "string",
          "description": "Primary phone number for the shop."
        },
        "registrationDate": {
          "type": "string",
          "description": "Timestamp when the seller registered.",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "description": "Current status of the shop.",
          "enum": ["pending", "approved", "rejected", "active", "suspended"]
        },
        "description": {
          "type": "string",
          "description": "A brief description of the shop."
        },
        "imageUrl": {
          "type": "string",
          "description": "Main URL for the shop image."
        },
        "location": {
          "type": "object",
          "description": "Geographical and address information for the shop.",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" },
            "city": { "type": "string" },
            "street": { "type": "string" }
          }
        }
      },
      "required": [
        "id",
        "name",
        "ownerName",
        "contactEmail",
        "registrationDate",
        "status"
      ]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a product offered for sale by a Seller on the platform.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Product entity."
        },
        "sellerId": {
          "type": "string",
          "description": "Reference to the Seller who owns this product."
        },
        "name": {
          "type": "string",
          "description": "The name of the product."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the product."
        },
        "price": {
          "type": "number",
          "description": "The price of the product."
        },
        "category": {
          "type": "string",
          "description": "Broad category like 'Fashion' or 'Kids'."
        },
        "subcategory": {
          "type": "string",
          "description": "Specific subcategory like 'Apparel' or 'Footwear'."
        },
        "status": {
          "type": "string",
          "description": "The current status of the product."
        },
        "creationDate": {
          "type": "string",
          "description": "Timestamp when the product was first created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "sellerId",
        "name",
        "price",
        "status",
        "creationDate"
      ]
    },
    "Ping": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Ping",
      "type": "object",
      "description": "Records a notification or small transaction between a buyer and a seller.",
      "properties": {
        "id": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "productId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "successful", "expired"] },
        "amount": { "type": "number" }
      },
      "required": ["id", "createdAt", "buyerId", "sellerId", "status"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/adminUsers/{adminId}",
        "definition": {
          "entityName": "AdminUser",
          "schema": { "$ref": "#/backend/entities/AdminUser" },
          "description": "Admin profiles for access control."
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "General user profiles."
        }
      },
      {
        "path": "/shops/{shopId}",
        "definition": {
          "entityName": "Seller",
          "schema": { "$ref": "#/backend/entities/Seller" },
          "description": "Seller shop profiles (mapped to 'shops' collection)."
        }
      },
      {
        "path": "/shops/{shopId}/products/{productId}",
        "definition": {
          "entityName": "Product",
          "schema": { "$ref": "#/backend/entities/Product" },
          "description": "Products within a shop."
        }
      },
      {
        "path": "/pings/{pingId}",
        "definition": {
          "entityName": "Ping",
          "schema": { "$ref": "#/backend/entities/Ping" },
          "description": "Global transaction pings for dashboard monitoring."
        }
      }
    ]
  }
}
